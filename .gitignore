# ─── OS Generated Files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor Files ──────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.buildpath
*.sublime-project
*.sublime-workspace
nbproject/

# ─── Klytos Runtime Data (NEVER commit) ──────────────────────
# These are generated at install time and contain encrypted secrets.
installer/config/.encryption_key
installer/config/config.json.enc
installer/config/database.json.enc
installer/config/license.json.enc
installer/config/plugin_licenses/
installer/config/.install.lock

# ─── Encrypted Data (user content) ───────────────────────────
installer/data/*.json.enc
installer/data/**/*.json.enc
installer/data/rate_limits.json
installer/data/logs/
installer/data/.transaction.lock
installer/data/.cron.lock

# ─── Backups ─────────────────────────────────────────────────
installer/backups/*.zip
installer/backups/*.tar.gz

# ─── Generated Static Site ───────────────────────────────────
# The public site is generated by the build engine.
installer/public/index.html
installer/public/**/*.html
installer/public/css/style.css
installer/public/sitemap.xml
installer/public/robots.txt
installer/public/llms.txt
installer/public/llms-full.txt

# ─── Uploaded Assets (user content) ──────────────────────────
installer/public/assets/images/
installer/public/assets/uploads/

# ─── Plugin Data ─────────────────────────────────────────────
# Third-party plugins should not be committed.
# Core-bundled plugins can be tracked selectively.
installer/plugins/*/
!installer/plugins/.htaccess

# ─── Install file (renamed after install) ────────────────────
installer/.install.done.php

# ─── PHP Dependencies ────────────────────────────────────────
# Only exclude root-level vendor/ (Composer). Admin vendor assets are tracked.
/vendor/
composer.lock

# ─── Node.js (if used for build tools) ───────────────────────
node_modules/
package-lock.json
yarn.lock

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ─── Environment Files ───────────────────────────────────────
.env
.env.local
.env.*.local
