# ─── OS Generated Files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor Files ──────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.buildpath
*.sublime-project
*.sublime-workspace
nbproject/

# ─── Klytos Runtime Data (NEVER commit) ──────────────────────
# These are generated at install time and contain encrypted secrets.
my-secret-folder/config/.encryption_key
my-secret-folder/config/config.json.enc
my-secret-folder/config/database.json.enc
my-secret-folder/config/license.json.enc
my-secret-folder/config/plugin_licenses/
my-secret-folder/config/.install.lock

# ─── Encrypted Data (user content) ───────────────────────────
my-secret-folder/data/*.json.enc
my-secret-folder/data/**/*.json.enc
my-secret-folder/data/rate_limits.json
my-secret-folder/data/logs/
my-secret-folder/data/.transaction.lock
my-secret-folder/data/.cron.lock

# ─── Backups ─────────────────────────────────────────────────
my-secret-folder/backups/*.zip
my-secret-folder/backups/*.tar.gz

# ─── Generated Static Site ───────────────────────────────────
# The public site is generated by the build engine.
my-secret-folder/public/index.html
my-secret-folder/public/**/*.html
my-secret-folder/public/css/style.css
my-secret-folder/public/sitemap.xml
my-secret-folder/public/robots.txt
my-secret-folder/public/llms.txt
my-secret-folder/public/llms-full.txt

# ─── Uploaded Assets (user content) ──────────────────────────
my-secret-folder/public/assets/images/
my-secret-folder/public/assets/uploads/

# ─── Plugin Data ─────────────────────────────────────────────
# Third-party plugins should not be committed.
# Core-bundled plugins can be tracked selectively.
my-secret-folder/plugins/*/
!my-secret-folder/plugins/.htaccess

# ─── Install file (renamed after install) ────────────────────
my-secret-folder/.install.done.php

# ─── PHP Dependencies ────────────────────────────────────────
# Only exclude root-level vendor/ (Composer). Admin vendor assets are tracked.
/vendor/
composer.lock

# ─── Node.js (if used for build tools) ───────────────────────
node_modules/
package-lock.json
yarn.lock

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ─── Environment Files ───────────────────────────────────────
.env
.env.local
.env.*.local
